# Raw downloaded catalogues and uncompressed processed data are large and
# reproducible — never commit them.
data_prep/output/
data_prep/cache/
data_prep/tmp/

# Local storage artifacts
storage/
!python_lib/storage/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.ruff_cache/
.mypy_cache/

# Node / client build
client/node_modules/
client/dist/
client/.svelte-kit/
client/.env.local
client/.env.development.local

# Vite's programmatic build() (used by client/scripts/render_moon.mjs) writes
# a transpiled copy of vite.config.mjs next to the original when loading it
# via `configFile`, and doesn't always clean it up.
client/vite.config.mjs.timestamp-*.mjs

# Terraform state (local backend — keep tfstate out of source control)
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/.terraform.lock.hcl
infra/lambda_function.zip

# macOS
.DS_Store

# Editor
.vscode/settings.json
.aider*
